          <mxGeometry x="10" y="40" width="320" height="50" as="geometry" />
        </mxCell>
        <mxCell id="t3_comp" value="run_model_competition()&#xa;─────────────&#xa;• Walk-Forward CV (5 folds × 4 meses)&#xa;• Excluye: COVID, Paros, Cambio IVA&#xa;• Modelos: XGBoost · RF · SARIMAX · Prophet&#xa;• Ganador = menor MAPE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="tab3_bg">
          <mxGeometry x="10" y="110" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="t3_final" value="run_final_forecast()&#xa;─────────────&#xa;• Reentrena ganador con 100% hist.&#xa;• Pronóstico dinámico (lags t-1, t-12,&#xa;  rolling 3m, 6m)&#xa;• 3 escenarios (N/O/P)&#xa;• IC = ±1.96 × RMSE_backtest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="tab3_bg">
          <mxGeometry x="10" y="250" width="320" height="130" as="geometry" />
        </mxCell>
