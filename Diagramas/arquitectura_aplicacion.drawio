          <mxGeometry x="10" y="400" width="320" height="110" as="geometry" />
        </mxCell>
        <mxCell id="t3_save" value="💾 Guarda: forecast_final_projections · forecast_runs · forecast_model_metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="tab3_bg">
