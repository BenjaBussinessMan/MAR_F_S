        <mxCell id="tab3_bg" value="📈 PESTAÑA 3 — Paso 2: Pronóstico de Ventas" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;fontColor=#4a235a;" vertex="1" parent="1">
