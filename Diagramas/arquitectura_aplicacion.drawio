        </mxCell>
        <mxCell id="t2_proj" value="project_future_drivers()&#xa;─────────────&#xa;• AutoARIMA (preferido)&#xa;• SARIMAX(1,1,1)(1,1,0,12)&#xa;• Fallback: último valor&#xa;Genera 3 escenarios:&#xa;Normal / Optimista / Pesimista" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=10;" vertex="1" parent="tab2_bg">
